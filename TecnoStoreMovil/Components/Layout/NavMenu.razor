@inject NavigationManager NavigationManager
@inject SesionService SesionService

<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
    <div class="container-fluid d-flex align-items-center justify-content-between">
        <!-- LOGO + TÍTULO + ICONOS -->
        <div class="d-flex align-items-center">
            <a class="navbar-brand fw-bold d-flex align-items-center me-2" href="@GetDashboardUrl()">
                <img src="images/logo_tecno.jpg" alt="Logo" style="height: 32px;" class="me-1" />
                TecnoStore
            </a>

            @if (SesionService.EstaLogueado)
            {
                <NavLink href="@GetDashboardUrl()" class="btn btn-link text-white me-2 p-0" title="Inicio">
                    <i class="bi bi-house-door-fill fs-5"></i>
                </NavLink>
            }

            @if (SesionService.EsCliente)
            {
                <NavLink href="/Carrito" class="btn btn-link text-white me-2 p-0" title="Mi carrito">
                    <i class="bi bi-cart4 fs-5"></i>
                </NavLink>

                <NavLink href="/PerfilCliente" class="btn btn-link text-white me-2 p-0" title="Editar perfil">
                    <i class="bi bi-gear fs-5"></i>
                </NavLink>
            }
        </div>

        <!-- Botón hamburguesa -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal"
                aria-controls="menuPrincipal" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</nav>

<div class="collapse navbar-collapse bg-dark shadow" id="menuPrincipal">
    <div class="container py-3" style="max-width: 320px;">
        <ul class="nav flex-column text-white">

            <!-- ADMINISTRADOR -->
            @if (SesionService.EsAdministrador)
            {
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="/AdminDashboard" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door-fill"></i>
                        <span class="text-wrap">Inicio</span>
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="usuarios">
                        <i class="bi bi-people-fill"></i>
                        <span class="text-wrap">Gestionar Usuarios</span>
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="productos">
                        <i class="bi bi-box-seam"></i>
                        <span class="text-wrap">Gestionar Productos</span>
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="GestionPedidos">
                        <i class="bi bi-basket-fill"></i>
                        <span class="text-wrap">Gestionar Pedidos</span>
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="AcercaDe">
                        <i class="bi bi-exclamation-circle"></i>
                        <span class="text-wrap">Acerca de</span>
                    </NavLink>
                </li>
            }

            <!-- CLIENTE -->
            @if (SesionService.EsCliente)
            {
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="/ClienteDashboard" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door-fill"></i>
                        <span class="text-wrap">Inicio</span>
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="/ProductosCliente">
                        <i class="bi bi-tags"></i>
                        <span class="text-wrap">Productos por Categoría</span>
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="/JuegoCliente">
                        <i class="bi bi-joystick"></i>
                        <span class="text-wrap">Juegos por Consola</span>
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="/Carrito">
                        <i class="bi bi-cart4"></i>
                        <span class="text-wrap">Mi Carrito</span>
                    </NavLink>
                </li>
                <!-- NUEVO ITEM: Mi Perfil -->
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="/PerfilCliente">
                        <i class="bi bi-person-circle"></i>
                        <span class="text-wrap">Mi Perfil</span>
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-start gap-2" href="AcercaDe">
                        <i class="bi bi-exclamation-circle"></i>
                        <span class="text-wrap">Acerca de</span>
                    </NavLink>
                </li>
            }

            @if (SesionService.EstaLogueado)
            {
                <li class="nav-item">
                    <hr class="border-light" />
                </li>

                <li class="nav-item">
                    <button class="btn btn-outline-light w-100 d-flex align-items-center justify-content-center" @onclick="CerrarSesion">
                        <i class="bi bi-box-arrow-right me-2"></i> Cerrar sesión
                    </button>
                </li>
            }
        </ul>
    </div>
</div>

@code {
    private void CerrarSesion()
    {
        SesionService.CerrarSesion();
        NavigationManager.NavigateTo("/");
    }

    private string GetDashboardUrl()
    {
        if (SesionService.EsAdministrador)
            return "/AdminDashboard";
        if (SesionService.EsCliente)
            return "/ClienteDashboard";
        return "/";
    }
}
