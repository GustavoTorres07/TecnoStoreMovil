@inherits LayoutComponentBase

<div class="login-page">
    <main class="login-main mt-5">
        <div class="login-card p-4">
            <div class="text-center mb-4">
                <img src="images/logo_tecno.jpg" alt="TecnoStore Logo" class="logo-img" />
