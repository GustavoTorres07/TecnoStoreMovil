@page "/ProductosCliente"
@inject ProductoService ProductoService
@inject CarritoService CarritoService
@inject SesionService SesionService

<h3 class="mt-4 text-center">🛒 Productos Disponibles</h3>

<!-- Filtros -->
<div class="container mt-3">
    <div class="row justify-content-center mb-4">
        <div class="col-md-6">
            <label class="form-label fw-bold">Seleccioná una categoría:</label>
            <select class="form-select" @bind="CategoriaSeleccionadaId">
                <option value="0">Todas las categorías</option>
                @foreach (var categoria in categorias)
                {
                    <option value="@categoria.Id">@categoria.Nombre</option>
                }
            </select>
        </div>
    </div>

    @if (EsCategoriaJuegos)
    {
        <div class="row justify-content-center mb-4">
            <div class="col-md-6">
                <label class="form-label fw-bold">Seleccioná una plataforma:</label>
                <select class="form-select" @bind="PlataformaSeleccionada">
                    <option value="">Todas las plataformas</option>
                    @foreach (var plataforma in Enum.GetValues<PlataformaJuego>())
                    {
                        <option value="@plataforma">@plataforma</option>
                    }
                </select>
            </div>
        </div>
    }
</div>

<!-- Mensaje si no hay productos -->
@if (productosFiltrados.Count == 0)
{
    if (EsCategoriaJuegos && PlataformaSeleccionada.HasValue)
    {
        <div class="alert alert-warning text-center mt-4">
            No hay juegos disponibles para la plataforma <strong>@PlataformaSeleccionada</strong>.
        </div>
    }
    else if (EsCategoriaJuegos)
    {
        <div class="alert alert-warning text-center mt-4">
            No hay juegos disponibles en este momento.
        </div>
    }
    else
    {
        <div class="alert alert-info text-center mt-4">
            No hay productos disponibles por el momento.
        </div>
    }
}
else
{
    <!-- Mostrar productos -->
    <div class="container mt-4">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
            @foreach (var producto in productosFiltrados)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <img src="@producto.ImagenProducto" class="card-img-top" alt="@producto.Nombre" style="object-fit: cover; height: 180px;" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@producto.Nombre</h5>
                            <p class="card-text text-muted">@producto.Descripcion</p>
                            <p class="fw-bold">💵 Precio: $@producto.Precio</p>
                            <p class="text-secondary mb-2">🛑 Últimos disponibles: <strong>@producto.Cantidad</strong></p>

                            <div class="input-group mb-3">
                                <button class="btn btn-outline-secondary" type="button" @onclick="() => DisminuirCantidad(producto.Id)">
                                    <i class="bi bi-dash"></i>
                                </button>

                                <input type="number" class="form-control text-center" min="1" max="@producto.Cantidad"
                                       @bind="cantidades[producto.Id]" />

                                <button class="btn btn-outline-secondary" type="button" @onclick="() => AumentarCantidad(producto.Id, producto.Cantidad)">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>

                            <button class="btn btn-success mt-auto w-100" @onclick="() => AgregarAlCarrito(producto)">
                                <i class="bi bi-cart-plus me-2"></i>Agregar al Carrito
                            </button>

                            <NavLink class="btn btn-outline-primary mt-2 w-100" href="@($"/ProductoDetalle/{producto.Id}")">
                                <i class="bi bi-eye me-2"></i>Ver Detalles
                            </NavLink>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Producto> productos = new();
    private List<Producto> productosFiltrados = new();
    private List<Categoria> categorias = new();
    private Dictionary<int, int> cantidades = new();

    private int categoriaSeleccionadaId;
    private PlataformaJuego? _plataformaSeleccionada;

    private string NombreCategoriaJuegos = "Juegos";

    // Propiedades con lógica personalizada
    private int CategoriaSeleccionadaId
    {
        get => categoriaSeleccionadaId;
        set
        {
            if (categoriaSeleccionadaId != value)
            {
                categoriaSeleccionadaId = value;
                PlataformaSeleccionada = null;
                FiltrarProductos();
            }
        }
    }

    private PlataformaJuego? PlataformaSeleccionada
    {
        get => _plataformaSeleccionada;
        set
        {
            if (_plataformaSeleccionada != value)
            {
                _plataformaSeleccionada = value;
                FiltrarProductos();
            }
        }
    }

    private bool EsCategoriaJuegos =>
        categorias.FirstOrDefault(c => c.Id == categoriaSeleccionadaId)?.Nombre == NombreCategoriaJuegos;

    protected override void OnInitialized()
    {
        productos = ProductoService.GetProductos().Where(p => p.Stock && p.Cantidad > 0).ToList();
        categorias = ProductoService.GetCategorias();

        CategoriaSeleccionadaId = 0;
        FiltrarProductos();
    }

    private void FiltrarProductos()
    {
        if (categoriaSeleccionadaId == 0)
        {
            productosFiltrados = productos.ToList();
        }
        else
        {
            productosFiltrados = productos.Where(p => p.CategoriaId == categoriaSeleccionadaId).ToList();

            if (EsCategoriaJuegos && PlataformaSeleccionada.HasValue)
            {
                productosFiltrados = productosFiltrados
                    .Where(p => p.Plataforma == PlataformaSeleccionada.Value)
                    .ToList();
            }
        }

        // Actualizar cantidades
        var nuevosIds = productosFiltrados.Select(p => p.Id).ToHashSet();
        foreach (var id in nuevosIds)
            if (!cantidades.ContainsKey(id))
                cantidades[id] = 1;

        var keysToRemove = cantidades.Keys.Except(nuevosIds).ToList();
        foreach (var k in keysToRemove)
            cantidades.Remove(k);
    }

    private void AumentarCantidad(int productoId, int max)
    {
        if (cantidades[productoId] < max)
            cantidades[productoId]++;
    }

    private void DisminuirCantidad(int productoId)
    {
        if (cantidades[productoId] > 1)
            cantidades[productoId]--;
    }

    private void AgregarAlCarrito(Producto producto)
    {
        var cantidad = cantidades.ContainsKey(producto.Id) ? cantidades[producto.Id] : 1;
        if (cantidad <= producto.Cantidad && cantidad > 0)
            CarritoService.AgregarItem(producto, cantidad);
    }
}
