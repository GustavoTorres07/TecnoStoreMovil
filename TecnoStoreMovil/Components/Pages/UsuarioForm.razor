@page "/usuario-form/{UsuarioId:int?}"
@using TecnoStoreMovil.Models
@inject UsuarioService UsuarioService
@inject NavigationManager NavigationManager

<h3>@(usuario.Id == 0 ? "Nuevo Usuario" : "Editar Usuario")</h3>

<EditForm Model="@usuario" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Nombre</label>
        <InputText class="form-control" @bind-Value="usuario.Nombre" />
    </div>
    <div class="mb-3">
        <label>Apellido</label>
        <InputText class="form-control" @bind-Value="usuario.Apellido" />
    </div>
    <div class="mb-3">
        <label>Email</label>
        <InputText class="form-control" @bind-Value="usuario.Email" />
    </div>
    <div class="mb-3">
        <label>Clave</label>
        <InputText class="form-control" type="password" @bind-Value="usuario.Clave" />
    </div>
    <div class="mb-3">
        <label>Celular</label>
        <InputText class="form-control" @bind-Value="usuario.Celular" />
    </div>
    <div class="mb-3">
        <label>Rol</label>
        <InputSelect class="form-control" @bind-Value="usuario.Rol">
            @foreach (var rol in Enum.GetValues<RolUsuario>())
            {
                <option value="@rol">@rol</option>
            }
        </InputSelect>
    </div>
    <div class="mb-3">
        <label>Foto (ruta local)</label>
        <InputText class="form-control" @bind-Value="usuario.FotoUsuario" />
        @if (!string.IsNullOrEmpty(usuario.FotoUsuario))
        {
            <img src="@usuario.FotoUsuario" class="mt-2" style="width:80px;height:80px;border-radius:50%" />
        }
    </div>
    <div class="mb-3 form-check">
        <InputCheckbox class="form-check-input" @bind-Value="usuario.Activo" />
        <label class="form-check-label">Activo</label>
    </div>

    <button class="btn btn-primary me-2" type="submit">Guardar</button>
    <button class="btn btn-secondary" type="button" @onclick="Cancelar">Cancelar</button>
</EditForm>

@code {
    [Parameter] public int? UsuarioId { get; set; }

    private Usuario usuario = new();

    protected override void OnInitialized()
    {
        if (UsuarioId.HasValue)
        {
            var existente = UsuarioService.GetUsuario(UsuarioId.Value);
            if (existente != null)
                usuario = new Usuario
                {
                    Id = existente.Id,
                    Nombre = existente.Nombre,
                    Apellido = existente.Apellido,
                    Email = existente.Email,
                    Clave = existente.Clave,
                    Celular = existente.Celular,
                    FechaRegistro = existente.FechaRegistro,
                    FotoUsuario = existente.FotoUsuario,
                    Rol = existente.Rol,
                    Activo = existente.Activo
                };
        }
    }

    private void Guardar()
    {
        if (usuario.Id == 0)
            UsuarioService.AddUsuario(usuario);
        else
            UsuarioService.UpdateUsuario(usuario);

        NavigationManager.NavigateTo("/usuarios");
    }

    private void Cancelar()
    {
        NavigationManager.NavigateTo("/usuarios");
    }
}
