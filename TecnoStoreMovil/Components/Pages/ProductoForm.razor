@page "/ProductoForm"
@page "/ProductoForm/{Id:int}"
@inject NavigationManager NavigationManager
@inject ProductoService ProductoService

<h3 class="mt-4 text-center">📦 @((producto.Id == 0) ? "Nuevo Producto" : "Editar Producto")</h3>

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow p-4">
        <EditForm Model="@producto" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label>Nombre</label>
                <InputText class="form-control" @bind-Value="producto.Nombre" />
            </div>

            <div class="mb-3">
                <label>Categoría</label>
                <select class="form-select" @bind="CategoriaId">
                    <option value="0">-- Seleccione una categoría --</option>
                    @foreach (var cat in categorias)
                    {
                        <option value="@cat.Id">@cat.Nombre</option>
                    }
                </select>
                <ValidationMessage For="@(() => producto.CategoriaId)" />
            </div>

            <div class="mb-3">
                <label>Descripción</label>
                <InputTextArea class="form-control" @bind-Value="producto.Descripcion" />
            </div>

            <div class="mb-3">
                <label>Precio</label>
                <InputNumber class="form-control" @bind-Value="producto.Precio" />
            </div>

            <div class="mb-3">
                <label>Imagen (ruta relativa)</label>
                <InputText class="form-control" @bind-Value="producto.ImagenProducto" />
            </div>

            <div class="mb-3">
                <label>Cantidad Disponible</label>
                <InputNumber class="form-control" @bind-Value="producto.Cantidad" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="producto.Stock" />
                <label class="form-check-label">Producto en Stock</label>
            </div>

            @if (EsJuego)
            {
                <hr />
                <div class="mb-3">
                    <label>Plataforma</label>
                    <select class="form-select" @bind="producto.Plataforma">
                        @foreach (var p in Enum.GetValues<PlataformaJuego>())
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label>Fecha de Lanzamiento</label>
                    <InputDate class="form-control" @bind-Value="producto.FechaLanzamiento" />
                </div>
            }

            <div class="d-flex justify-content-end gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Guardar
                </button>
                <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                    Cancelar
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private Producto producto = new();
    private List<Categoria> categorias = new();
    private bool EsJuego = false;
    private string NombreCategoriaJuegos = "Juegos"; // nombre exacto en la lista

    private int categoriaId;
    private int CategoriaId
    {
        get => categoriaId;
        set
        {
            if (categoriaId != value)
            {
                categoriaId = value;
                producto.CategoriaId = value;
                VerificarCategoria();
            }
        }
    }

    protected override void OnInitialized()
    {
        categorias = ProductoService.GetCategorias();

        if (Id.HasValue)
        {
            var existente = ProductoService.GetProducto(Id.Value);
            if (existente != null)
                producto = existente;
        }

        categoriaId = producto.CategoriaId;
        VerificarCategoria();
    }

    private void VerificarCategoria()
    {
        var categoriaSeleccionada = categorias.FirstOrDefault(c => c.Id == producto.CategoriaId);
        EsJuego = categoriaSeleccionada?.Nombre == NombreCategoriaJuegos;
    }

    private void Guardar()
    {
        if (producto.Id == 0)
            ProductoService.AddProducto(producto);
        else
            ProductoService.UpdateProducto(producto);

        NavigationManager.NavigateTo("/Productos");
    }

    private void Cancelar()
    {
        NavigationManager.NavigateTo("/Productos");
    }
}
