@page "/admin/categorias"
@inject CategoriaService CategoriaService

<h3 class="mt-4 mb-4">Gestión de Categorías</h3>

<div class="row">
    <div class="col-md-4">
        <h5>@(categoriaEdit.Id == 0 ? "Agregar Nueva Categoría" : "Editar Categoría")</h5>

        <EditForm Model="categoriaEdit" OnValidSubmit="GuardarCategoria">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Nombre</label>
                <InputText class="form-control" @bind-Value="categoriaEdit.Nombre" />
            </div>
            <div class="mb-3">
                <label class="form-label">Descripción</label>
                <InputTextArea class="form-control" @bind-Value="categoriaEdit.Descripcion" />
            </div>

            <div class="form-check mb-3">
                <InputCheckbox class="form-check-input" @bind-Value="categoriaEdit.Activo" />
                <label class="form-check-label">Activo</label>
            </div>

            <button type="submit" class="btn btn-primary me-2">
                <i class="bi bi-save2 me-1"></i> Guardar
            </button>
            <button type="button" class="btn btn-secondary" @onclick="CancelarEdicion">
                <i class="bi bi-x-circle me-1"></i> Cancelar
            </button>
        </EditForm>
    </div>

    <div class="col-md-8">
        <h5>Categorías Existentes</h5>
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Activo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in categorias)
                {
                    <tr>
                        <td>@cat.Nombre</td>
                        <td>@cat.Descripcion</td>
                        <td>
                            @if (cat.Activo)
                            {
                                <span class="badge bg-success">Sí</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditarCategoria(cat)">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarCategoria(cat.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Categoria> categorias = new();
    private Categoria categoriaEdit = new();

    protected override void OnInitialized()
    {
        CargarCategorias();
    }

    private void CargarCategorias()
    {
        categorias = CategoriaService.ObtenerTodas();
        categoriaEdit = new Categoria(); // limpia formulario
    }

    private void GuardarCategoria()
    {
        if (categoriaEdit.Id == 0)
            CategoriaService.Agregar(categoriaEdit);
        else
            CategoriaService.Actualizar(categoriaEdit);

        CargarCategorias();
    }

    private Task EditarCategoria(Categoria categoria)
    {
        categoriaEdit = new Categoria
        {
            Id = categoria.Id,
            Nombre = categoria.Nombre,
            Descripcion = categoria.Descripcion,
            Activo = categoria.Activo
        };

        return Task.CompletedTask;
    }

    private Task CancelarEdicion()
    {
        categoriaEdit = new Categoria();
        return Task.CompletedTask;
    }

    private Task EliminarCategoria(int id)
    {
        CategoriaService.Eliminar(id);
        CargarCategorias();
        return Task.CompletedTask;
    }
}
